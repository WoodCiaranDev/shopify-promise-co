        },
        "richtext_paPaDA": {
          "type": "richtext",
          "settings": {
            "content": "<p>At The Promise Co, promise rings are at the heart of everything we do.<br/><br/>A promise ring represents commitment, loyalty, and the intention to build a future together. Whether you’re celebrating a new relationship, marking an important milestone, or giving a meaningful gift, a promise ring captures that moment in a piece of jewellery designed to be worn every day.<br/><br/>Our collections bring together timeless designs, modern craftsmanship, and high-quality stones to create promise rings that feel special.<br/><br/>From delicate styles designed for her, to minimal bands for him, to matching rings for couples, every design in our collection reflects the same idea, a meaningful promise between two people.</p>"
          }
        }
      },
