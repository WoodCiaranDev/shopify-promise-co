    "faq_FqWbPD": {
      "type": "faq",
      "blocks": {
        "question_Lq96MW": {
          "type": "question",
          "settings": {
            "question": "How long will my order take to ship?",
            "answer": "<p><strong>Order Fulfilment</strong></p><ul><li>Orders are shipped <strong>Monday–Friday</strong>.</li><li>Any orders placed after <strong>1pm (local warehouse time)</strong> on Friday will not be shipped until Monday.</li></ul><p><strong>UK Shipping (from our UK warehouse)</strong></p><ul><li><strong>Royal Mail 48 Hours</strong>: Delivery in 2 working days.</li><li><strong>Royal Mail 24 Hours</strong>: Delivery in 1 working day (order before 1pm GMT to receive your parcel the next working day).</li></ul><p><strong>USA Shipping (from our USA warehouse)</strong></p><ul><li>Orders ship via <strong>DHL Express Domestic</strong>.</li><li>Delivery takes <strong>2–4 working days</strong>, depending on your shipping zone.</li><li>All tariffs and import fees are already covered by <strong>The Promise Ring Co. LTD</strong>, so there are <strong>no additional customs charges</strong> for US customers.</li></ul><p><strong>International Shipping (all other countries from our UK warehouse)</strong></p><ul><li><strong>Europe</strong>: 2–11 business days.</li><li><strong>Rest of the World (Canada, Australia, etc.)</strong>: 3–17 business days.</li></ul><p><strong>Please note:</strong> Delivery times are estimates and may occasionally be extended due to customs delays, courier disruptions, or UK bank holidays.</p>"
          }
        },
        "question_7gTgX8": {
          "type": "question",
          "settings": {
            "question": "Can I return my order?",
            "answer": "<p>Yes! If your ring doesn't fit, or you simply don't like it, you can return it by emailing <strong>info@thepromiseco.com</strong></p><p>We will refund any item you are unhappy with if returned to us in its <strong>original, unaltered condition </strong>within <strong>30 days </strong>from when you received it.</p><p><strong>Please see our refund policy for full details.</strong></p>"
          }
        },
        "question_XjwjE8": {
          "type": "question",
          "settings": {
            "question": "When will my refund be processed?",
            "answer": "<p>We will notify you once we’ve received and inspected your return, once your refund is approved please allow up to 10 working days for your bank to have reversed the transaction.</p><p>Please see our refund policy for full details.</p>"
          }
        },
        "question_FDh8CK": {
          "type": "question",
          "settings": {
            "question": "Can I exchange my order?",
            "answer": "<p>We want to make sure your ring fits just right! If it doesn't, you're eligible for an exchange.</p><p>Please email <strong>info@thepromiseco.com </strong>to start the process</p><p>We will exchange any item you are unhappy with if returned to us in its <strong>original, unaltered condition </strong>within <strong>30</strong> <strong>days </strong>from when you received it.</p>"
          }
        },
        "question_4tpEA8": {
          "type": "question",
          "settings": {
            "question": "I'm buying as a gift and your return window is not long enough, what can I do?",
            "answer": "<p>We appreciate that when it comes to unique gifts, you prefer to plan ahead. Before making your purchase, kindly reach out to us at <a>info@thepromiseco.com</a>, and we'll be happy to assist you.</p><p>If a longer timeframe is authorised, we can arrange this on an exchanges only basis (no cash refunds), provided that the ring passes our quality inspection upon return.</p>"
          }
        },
        "question_ykm4gj": {
          "type": "question",
          "settings": {
            "question": "Do you do express delivery?",
            "answer": "<p><strong>Express Delivery</strong></p><ul><li><strong>UK Customers</strong> – Next Working Day delivery available with Royal Mail (order before 1pm).<br/></li><li><strong>USA Customers</strong> – Express shipping available nationwide, delivered in <strong>2–4 business days</strong>.</li></ul><p>Unfortunately for Rest of World orders we do not offer any express delivery.</p>"
          }
        },
        "question_zk7DQT": {
          "type": "question",
          "settings": {
            "question": "Will you cover the cost of my return?",
            "answer": "<p>If it is proven that there is a fault with the good once inspected, we will credit you the cost of your return. There otherwise returns are at the cost of the customer.</p><p>Please see the refund policy for details.</p>"
          }
        },
        "question_bdAUN3": {
          "type": "question",
          "settings": {
            "question": "International Charges",
            "answer": "<p><strong>UK Customers</strong> – No duties or fees apply.</p><p><br/><strong>USA Customers</strong> – Thanks to our new US warehouse, there are <strong>no tariffs or additional fees</strong> on your orders.<br/></p><p><strong>EU Customers -</strong>Orders under €150 (excluding shipping fees) ship with no import fees</p><p><br/><strong>Other International Customers</strong> – Deliveries outside of the UK and USA may be subject to customs duties and service fees. These vary by country, and unfortunately we cannot control or predict the charges. For more information, please contact your local customs office. Please note, we are not able to reimburse duties or taxes paid upon delivery.</p>"
          }
        }
