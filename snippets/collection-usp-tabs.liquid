      </div>
    {%- endif -%}

    {%- comment -%} Tab 4 {%- endcomment -%}
    {%- assign tab_4_title = settings.usp_tab_4_title -%}
    {%- assign tab_4_icon = settings.usp_tab_4_icon -%}
    {%- if market_type == 'usa' -%}
      {%- if settings.usp_tab_4_title_usa != blank -%}{%- assign tab_4_title = settings.usp_tab_4_title_usa -%}{%- endif -%}
      {%- if settings.usp_tab_4_icon_usa != blank -%}{%- assign tab_4_icon = settings.usp_tab_4_icon_usa -%}{%- endif -%}
    {%- elsif market_type == 'eu' -%}
      {%- if settings.usp_tab_4_title_eu != blank -%}{%- assign tab_4_title = settings.usp_tab_4_title_eu -%}{%- endif -%}
      {%- if settings.usp_tab_4_icon_eu != blank -%}{%- assign tab_4_icon = settings.usp_tab_4_icon_eu -%}{%- endif -%}
    {%- elsif market_type == 'default' -%}
      {%- if settings.usp_tab_4_title_default != blank -%}{%- assign tab_4_title = settings.usp_tab_4_title_default -%}{%- endif -%}
      {%- if settings.usp_tab_4_icon_default != blank -%}{%- assign tab_4_icon = settings.usp_tab_4_icon_default -%}{%- endif -%}
    {%- endif -%}
    {%- if tab_4_title != blank -%}
      <div class="collection-usp-tab">
        {%- if tab_4_icon != blank -%}
          <div class="collection-usp-tab__icon">
            {{ tab_4_icon | image_url: width: 160 | image_tag: loading: 'lazy' }}
          </div>
        {%- endif -%}
        <span class="collection-usp-tab__title">{{ tab_4_title }}</span>
      </div>
    {%- endif -%}
  </div>
</div>
