{% comment %} Detect active filters for variant options {% endcomment %}
{% assign active_option_filters = blank %}
{% assign has_active_filters = false %}

{% comment %} Check collection filters to detect active variant option filters {% endcomment %}
{% if collection.filters %}
  {% for filter in collection.filters %}
    {% if filter.active_values.size > 0 %}
      {% for active_value in filter.active_values %}
        {% comment %} Store active filter values for variant matching {% endcomment %}
        {% assign filter_key = filter.label | downcase %}
        {% if filter_key contains 'color' or filter_key contains 'colour' or filter_key contains 'metal' or filter_key contains 'material' or filter_key contains 'finish' or filter_key contains 'stone' %}
          {% assign has_active_filters = true %}
          {% if active_option_filters == blank %}
            {% assign active_option_filters = active_value.label %}
          {% else %}
            {% assign active_option_filters = active_option_filters | append: '|' | append: active_value.label %}
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}
{% endif %}

{% comment %} Fallback: if we can't access collection filters, check search filters for search pages {% endcomment %}
{% unless has_active_filters %}
  {% if search.filters %}
    {% for filter in search.filters %}
      {% if filter.active_values.size > 0 %}
        {% for active_value in filter.active_values %}
          {% assign filter_key = filter.label | downcase %}
          {% if filter_key contains 'color' or filter_key contains 'colour' or filter_key contains 'metal' or filter_key contains 'material' or filter_key contains 'finish' or filter_key contains 'stone' %}
            {% assign has_active_filters = true %}
            {% if active_option_filters == blank %}
              {% assign active_option_filters = active_value.label %}
            {% else %}
              {% assign active_option_filters = active_option_filters | append: '|' | append: active_value.label %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endunless %}

{% assign color_active = false %}
{% for option in product.options %}
  {% if option == 'Color' or option == 'Colour' or option == 'Precious Metal' %}
    {% assign color_active = true %}
  {% endif %}
{% endfor %}

{% if product.variants.size > 1 and color_active == true %}
  {% assign variants_shown = 0 %}
  
  {% for option in product.options %}
      {% if option == 'Color' or option == 'Colour' or option == 'Precious Metal' %}
      {% assign index = forloop.index0 %}
      {% assign colorlist = '' %}
      {% assign color = '' %}
      {% for variant in product.variants %}
      {% capture color %}
      {{ variant.options[index] }}
      {% endcapture %}
  
        {% unless colorlist contains color %}
          {% comment %} Check if this variant matches active filters {% endcomment %}
          {% assign show_variant = true %}
          {% if has_active_filters %}
            {% assign show_variant = false %}
            {% comment %} Check if any active filter matches this variant's options {% endcomment %}
            {% assign active_filters_array = active_option_filters | split: '|' %}
            {% for active_filter in active_filters_array %}
              {% for variant_option in variant.options %}
                {% if variant_option == active_filter %}
                  {% assign show_variant = true %}
                  {% break %}
                {% endif %}
              {% endfor %}
              {% if show_variant %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}

          {% if show_variant %}
            {% assign lazy_load = false %}
            {%- if forloop.index > 2 -%}
              {%- assign lazy_load = true -%}
            {%- endif -%}
              {% render 'color-product-card', 
                variant_sel : variant,
                product: product,
                reveal: reveal, 
                hide_product_information: hide_product_information, 
                stacked: true
              %}
              {% assign variants_shown = variants_shown | plus: 1 %}
          {% endif %}
          
          {% capture tempList %}
        {{colorlist | append: color | append: " " }}
        {% endcapture %}
        {% assign colorlist = tempList %}
        {% endunless %}
        {% endfor %}
      {% endif %}
    {% endfor %}
  
  {% comment %} Fallback: if no variants were shown (filter too restrictive), show first available variant {% endcomment %}
  {% if variants_shown == 0 and has_active_filters %}
    {% for variant in product.variants limit: 1 %}
      {% render 'color-product-card', 
        variant_sel : variant,
        product: product,
        reveal: reveal, 
        hide_product_information: hide_product_information, 
        stacked: true
      %}
    {% endfor %}
  {% endif %}
{% else %}
{% render 'product-card',
  product: product,
  reveal: reveal, 
  hide_product_information: hide_product_information, 
  stacked: true
%}
{% endif %}