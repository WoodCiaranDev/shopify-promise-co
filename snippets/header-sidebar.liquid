{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
HEADER SIDEBAR COMPONENT
----------------------------------------------------------------------------------------------------------------------

This snippet the navigation sidebar for the header. It is used for both the mobile menu and for the desktop menu when
the merchant configures the drawer mode.

********************************************
Supported variables
********************************************

* menu: the menu to render
* color_scheme: the color scheme to use for the sidebar
* show_dividers: whether dividers are shown for the collapsible
* open_second_level_menus: if true, second level dropdown are open by default
{%- endcomment -%}

{%- comment -%}
IMPLEMENTATION NOTE: while being a drawer, the sidebar has a completely different structure for the content. We are
therefore using a different structure for the Shadow DOM template
{%- endcomment -%}

<style>
  .header-sidebar__main-panel {
    background-color: #F2EEE8 !important;
    background-image: none !important;
    grid-template-rows: auto minmax(0, 1fr) auto;
  }
  
  .header-sidebar__collapsible-panel {
    background-color: #F2EEE8 !important;
    background-image: none !important;
  }
  
  .header-sidebar__footer:before {
    background: linear-gradient(transparent, #F2EEE8) !important;
  }
  
  .header-sidebar::part(header) {
    background-color: #F2EEE8 !important;
    padding: 0 !important;
  }
  
  .header-sidebar__header {
    padding: 0.75rem var(--drawer-header-padding-inline);
  }
  
  .header-sidebar__header .localization-selectors {
    justify-content: flex-start;
    gap: 1rem;
    color: #000000 !important;
  }
  
  .header-sidebar__header .localization-toggle {
    color: #000000 !important;
  }
  
  .header-sidebar::part(close-button) {
    position: absolute !important;
    top: 1rem !important;
    right: 1rem !important;
    z-index: 10 !important;
  }
  
  .header-sidebar__main-panel .header-sidebar__linklist-button {
    font-family: "minerva-modern", serif !important;
    font-size: 16px !important;
    text-transform: uppercase !important;
  }
  
  .header-sidebar__back-to-main {
    font-family: "covik-sans", sans-serif !important;
    font-size: 12px !important;
    text-transform: uppercase !important;
    color: #000000 !important;
    padding: 0.75rem var(--drawer-header-padding-inline) !important;
    display: flex !important;
    align-items: center !important;
    text-decoration: none !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1) !important;
    margin-bottom: 0.5rem !important;
    gap: 10px !important;
  }
</style>

<template id="header-sidebar-template">
  <div part="base">
    <div part="overlay"></div>

    <div part="content" style="background-color: #F2EEE8;">
      <header part="header">
        <dialog-close-button class="contents">
          <button type="button" part="close-button tap-area" aria-label="{{ 'general.accessibility.close' | t | escape }}">
            {%- render 'icon' with 'close', width: 16 -%}
          </button>
        </dialog-close-button>
      </header>

      <div part="panel-list">
        <slot name="main-panel"></slot>

        {%- if menu.levels > 0 -%}
          <slot name="collapsible-panel"></slot>
        {%- endif -%}
      </div>
    </div>
  </div>
</template>

<header-sidebar id="sidebar-menu" class="header-sidebar drawer drawer--sm color-scheme color-scheme--{{ color_scheme.id }}" template="header-sidebar-template" open-from="left" style="--drawer-background: #F2EEE8;">
  {%- comment -%}We are using a Shadow DOM where each panel has a slot, so we can directly render each level individually{%- endcomment -%}

  {%- comment -%}Panel 1 is the first level{%- endcomment -%}
  <div class="header-sidebar__main-panel" slot="main-panel">
    {%- liquid
      if section.settings.show_country_selector and localization.available_countries.size > 1
        assign show_country_selector = true
      endif

      if section.settings.show_locale_selector and localization.available_languages.size > 1
        assign show_locale_selector = true
      endif
    -%}

    {%- if show_country_selector or show_locale_selector -%}
      <div class="header-sidebar__header">
        <div class="localization-selectors">
          {%- if show_country_selector -%}
            {%- render 'localization-selector', type: 'country', placement: 'bottom-start', show_country_name: section.settings.show_country_name, show_country_flag: false, id_prefix: 'header-sidebar' -%}
          {%- endif -%}

          {%- if show_country_selector and show_locale_selector -%}
            <span class="localization-selectors__separator" aria-hidden="true"></span>
          {%- endif -%}

          {%- if show_locale_selector -%}
            {%- render 'localization-selector', type: 'locale', placement: 'bottom-start', id_prefix: 'header-sidebar' -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="header-sidebar__scroller">
      <ul class="header-sidebar__linklist {% if show_dividers %}divide-y{% endif %} unstyled-list" role="list">
        {%- for link in menu.links -%}
          <li>
            {%- if link.links.size > 0 -%}
              <button type="button" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}" aria-controls="header-panel-{{ forloop.index }}" aria-expanded="false">
                {{- link.title -}}
                {%- render 'icon' with 'chevron-right', width: 12, direction_aware: true -%}
              </button>
            {%- else -%}
              <a href="{{ link.url }}" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                {{- link.title -}}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- if shop.customer_accounts_enabled -%}
      <div class="header-sidebar__footer">
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="text-with-icon smallcaps sm:hidden">
          {%- render 'icon' with 'account', width: 20 -%}
          
          {%- if customer -%}
            {{- 'header.general.account' | t -}}
          {%- else -%}
            {{- 'header.general.login' | t -}}
          {%- endif -%}
        </a>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%}Panel 2 holds all the second levels{%- endcomment -%}
  {%- if menu.levels > 0 -%}
    <header-sidebar-collapsible-panel class="header-sidebar__collapsible-panel" slot="collapsible-panel">
      <div class="header-sidebar__scroller">
        {%- comment -%}Second level panels{%- endcomment -%}
        {%- for link in menu.links -%}
          {%- if link.links.size > 0 -%}
            <div id="header-panel-{{ forloop.index }}" class="header-sidebar__sub-panel" hidden>
              <a href="#" class="header-sidebar__back-to-main" data-action="close-panel">
                {%- render 'icon' with 'arrow-left', width: 12, direction_aware: true -%}
                BACK TO MAIN MENU
              </a>

              <ul class="header-sidebar__linklist {% if show_dividers %}divide-y{% endif %} unstyled-list" role="list">
                {%- for sub_link in link.links -%}
                  <li>
                    {%- if sub_link.links.size > 0 -%}
                      <button type="button" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}" aria-controls="header-subpanel-{{ forloop.parentloop.index }}-{{ forloop.index }}" aria-expanded="false">
                        {{- sub_link.title -}}
                        {%- render 'icon' with 'chevron-right', width: 12, direction_aware: true -%}
                      </button>
                    {%- else -%}
                      <a href="{{ sub_link.url }}" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                        {{- sub_link.title -}}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>

              {%- liquid
                assign link_title_downcase = link.title | strip | downcase
                assign mega_menu_block = ''

                for block in section.blocks
                  assign menu_item_downcase = block.settings.menu_item | strip | downcase

                  if menu_item_downcase == link_title_downcase
                    assign mega_menu_block = block
                    break
                  endif

                endfor
              -%}

              {%- capture mega_menu_content -%}
                {%- render 'mega-menu', link: link, block: mega_menu_block -%}
              {%- endcapture -%}

              {%- if mega_menu_content != blank -%}
                <div class="header-sidebar__promo scroll-area bleed md:unbleed hidden lg:block">
                  {{- mega_menu_content -}}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
        
        {%- comment -%}Third level panels{%- endcomment -%}
        {%- for link in menu.links -%}
          {%- if link.links.size > 0 -%}
            {%- for sub_link in link.links -%}
              {%- if sub_link.links.size > 0 -%}
                <div id="header-subpanel-{{ forloop.parentloop.index }}-{{ forloop.index }}" class="header-sidebar__sub-panel" hidden>
                  <a href="#" class="header-sidebar__back-to-main" data-action="close-panel">
                    {%- render 'icon' with 'arrow-left', width: 12, direction_aware: true -%}
                    BACK TO MAIN MENU
                  </a>

                  <ul class="header-sidebar__linklist {% if show_dividers %}divide-y{% endif %} unstyled-list" role="list">
                    {%- for sub_sub_link in sub_link.links -%}
                      <li>
                        <a href="{{ sub_sub_link.url }}" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                          {{- sub_sub_link.title -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </header-sidebar-collapsible-panel>
  {%- endif -%}
</header-sidebar>

<script>
// Fix third-level navigation by working with theme's native system
customElements.whenDefined('header-sidebar-collapsible-panel').then(() => {
  const headerSidebar = document.getElementById('sidebar-menu');
  if (!headerSidebar) return;
  
  const collapsiblePanel = headerSidebar.querySelector('header-sidebar-collapsible-panel');
  if (!collapsiblePanel) return;
  
  // Override the theme's openCollapsiblePanel method to handle third-level panels
  const originalHandler = collapsiblePanel.openCollapsiblePanel;
  
  collapsiblePanel.openCollapsiblePanel = function(panelId) {
    console.log('Opening panel:', panelId);
    
    // If it's a third-level panel (contains 'subpanel'), handle it manually
    if (panelId && panelId.includes('subpanel')) {
      // Hide all third-level panels
      const allThirdPanels = this.querySelectorAll('[id^="header-subpanel-"]');
      allThirdPanels.forEach(panel => {
        panel.setAttribute('hidden', '');
      });
      
      // Show the target panel
      const targetPanel = this.querySelector('#' + panelId);
      if (targetPanel) {
        targetPanel.removeAttribute('hidden');
        console.log('SUCCESS: Third-level panel is now visible!');
      }
      
      // Set aria-activedescendant to match theme's pattern
      this.setAttribute('aria-activedescendant', panelId);
      return;
    }
    
    // For regular panels, use the original handler if it exists
    if (originalHandler) {
      return originalHandler.call(this, panelId);
    }
  };
  
  // Also listen for click events as a backup
  collapsiblePanel.addEventListener('click', function(event) {
    const button = event.target.closest('button[aria-controls^="header-subpanel-"]');
    if (button) {
      const panelId = button.getAttribute('aria-controls');
      if (panelId) {
        this.openCollapsiblePanel(panelId);
        button.setAttribute('aria-expanded', 'true');
        
        // Set other buttons in the same panel to false
        const currentPanel = button.closest('.header-sidebar__sub-panel');
        if (currentPanel) {
          const siblings = currentPanel.querySelectorAll('button[aria-controls^="header-subpanel-"]');
          siblings.forEach(btn => {
            if (btn !== button) {
              btn.setAttribute('aria-expanded', 'false');
            }
          });
        }
      }
    }
  });
});
</script>

