<cart-drawer id="cart-drawer" class="cart-drawer drawer {% if cart.empty? %}drawer--center-body{% endif %} color-scheme color-scheme--scheme-2" initial-focus="false" handle-editor-events>
  <p class="h4" slot="header">{{ 'cart.general.title' | t }}</p>
  {%- if cart.empty? -%}
    <p class="h5 text-center">{{ 'cart.general.empty' | t }}</p>
  {%- else -%}
    <div class="cart-drawer__items">
      {%- for line_item in cart.items -%}
        {%- render 'line-item', line_item: line_item, show_quantity_selector: true -%}
      {%- endfor -%}
    </div>

    {%- liquid
      # Collect cross-sell products from cart items' metafields
      assign cross_sell_product_ids = ''

      for line_item in cart.items
        assign complementary = line_item.product.metafields['shopify--discovery--product_recommendation'].complementary_products.value
        if complementary and complementary.size > 0
          for rec_product in complementary
            # Check if product is already in cart
            assign in_cart = cart.items | where: 'product_id', rec_product.id
            # Check if we already added this product to cross-sells
            assign id_string = rec_product.id | append: ','

            unless cross_sell_product_ids contains id_string
              if in_cart.size == 0 and rec_product.available
                assign cross_sell_product_ids = cross_sell_product_ids | append: id_string
              endif
            endunless
          endfor
        endif
      endfor
    -%}

    {%- if cross_sell_product_ids != '' -%}
      <div class="cart-drawer__complementary-products complementary-products">
        {%- if section.settings.cross_sell_title != blank -%}
          <div class="complementary-products__header">
            <p class="h6">{{ section.settings.cross_sell_title }}</p>
          </div>
        {%- endif -%}

        <div class="complementary-products__product-list">
          {%- assign rendered_count = 0 -%}
          {%- for line_item in cart.items -%}
            {%- if rendered_count >= 3 -%}{%- break -%}{%- endif -%}
            {%- assign complementary = line_item.product.metafields['shopify--discovery--product_recommendation'].complementary_products.value -%}
            {%- if complementary -%}
              {%- for rec_product in complementary -%}
                {%- if rendered_count >= 3 -%}{%- break -%}{%- endif -%}
                {%- assign in_cart = cart.items | where: 'product_id', rec_product.id -%}
                {%- assign id_check = rec_product.id | append: ',' -%}
                {%- if in_cart.size == 0 and rec_product.available and cross_sell_product_ids contains id_check -%}
                  {%- assign cross_sell_product_ids = cross_sell_product_ids | remove_first: id_check -%}
                  {%- render 'product-card', product: rec_product, show_rating: true, show_quick_buy: false, hide_judgeme_badge: true, show_add_to_cart_button: true -%}
                  {%- assign rendered_count = rendered_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <form action="{{ routes.cart_url }}" method="POST" class="cart-drawer__footer" slot="footer">
      <input type="hidden" name="attributes[products_mobile_grid_mode]" value="">
      <input type="hidden" name="attributes[products_desktop_grid_mode]" value="">

      {%- if settings.gifting_show_checkbox_1 or settings.gifting_show_checkbox_2 -%}
        <div class="cart-drawer__gifting-option">
          {%- render 'luxury-pouch-option', section_id: section.id -%}
        </div>
      {%- endif -%}

      <div class="cart-drawer__subtotal">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <span>{{ cart.total_price | money }}</span>
      </div>

      {%- if settings.cart_show_free_shipping_bar -%}
        {%- render 'free-shipping-bar' -%}
      {%- endif -%}

      {% for discount_application in cart.cart_level_discount_applications %}
        <div class="h-stack justify-start gap-4">
          <span class="discount-badge text-xs">{%- render 'icon' with 'discount', width: 12 -%} {{- discount_application.title -}}</span>
          <span class="text-subdued">-{{ discount_application.total_allocated_amount | money }}</span>
        </div>
      {% endfor %}

      <div class="button-group">
        {%- if section.settings.show_view_cart_button or section.settings.show_checkout_button == false -%}
          {%- assign view_cart = 'cart.general.view_cart' | t -%}
          {%- render 'button', href: routes.cart_url, content: view_cart, stretch: true -%}
        {%- endif -%}

        {%- if section.settings.show_checkout_button -%}
          {%- render 'button', type: 'submit', content: 'Checkout', name: 'checkout', stretch: true -%}
        {%- endif -%}
      </div>
    </form>
  {%- endif -%}
</cart-drawer>

{% schema %}
{
  "name": "t:sections.cart_drawer.name",
  "class": "shopify-section--cart-drawer",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.cart_drawer.page_info"
    },
    {
      "type": "paragraph",
      "content": "t:sections.cart_drawer.free_shipping_bar_info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "t:sections.cart_drawer.show_cart_note",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping_text",
      "label": "t:sections.cart_drawer.show_shipping_text",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_cart_button",
      "label": "t:sections.cart_drawer.show_view_cart_button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_checkout_button",
      "label": "t:sections.cart_drawer.show_checkout_button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price_in_checkout_button",
      "label": "t:sections.cart_drawer.show_price_in_checkout_button",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.cart_drawer.cross_sell_category"
    },
    {
      "type": "product_list",
      "id": "cross_sell_products",
      "label": "t:sections.cart_drawer.cross_sell_products",
      "info": "t:sections.cart_drawer.cross_sell_products_info",
      "limit": 5
    },
    {
      "type": "inline_richtext",
      "id": "cross_sell_title",
      "label": "t:sections.cart_drawer.cross_sell_heading",
      "default": "Complete with"
    },
    {
      "type": "checkbox",
      "id": "cross_sell_stack_products",
      "label": "t:sections.cart_drawer.cross_sell_stack_products",
      "default": false
    },
    {
      "type": "paragraph",
      "content": "Gifting options are now configured in Theme Settings > Gifting & Packaging"
    }
  ]
}
{% endschema %}