{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
SIZE GUIDE POPUP
----------------------------------------------------------------------------------------------------------------------

A centered modal popup showing ring size conversion chart with an editable table.
Triggered via aria-controls targeting the modal ID or clicking a link with href="#size-guide-popup".
{%- endcomment -%}

<x-modal id="size-guide-popup" class="size-guide-popup modal color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
  <p class="h5 sr-only" slot="header">{{ section.settings.title }}</p>

  <div class="size-guide-popup__container">
    <div class="size-guide-popup__card">
      <dialog-close-button class="contents">
        <button type="button" class="size-guide-popup__close-button">
          <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
          {%- render 'icon' with 'close' -%}
        </button>
      </dialog-close-button>

      {%- if section.settings.title != blank -%}
        <h2 class="size-guide-popup__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- assign pdf_url = settings.size_guide_pdf_url | default: section.settings.pdf_url -%}
      {%- if pdf_url == blank -%}
        {%- assign pdf_url = 'size-guide-promise-co-130126.pdf' | file_url -%}
      {%- endif -%}
      <div class="size-guide-popup__intro prose">
        <p>Not sure on your sizing? Need to secretly measure for a loved one? Find <a href="{{ pdf_url }}" target="_blank" rel="noopener" download style="text-decoration: underline;">our handy printable PDF</a>.</p>
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="size-guide-popup__table-wrapper">
          <table class="size-guide-popup__table">
            <thead>
              <tr>
                <th>US/Promise Co</th>
                <th>Diameter (mm)</th>
                <th>Circumference (mm)</th>
                <th>UK</th>
                <th>Europe</th>
              </tr>
            </thead>
            <tbody>
              {%- for block in section.blocks -%}
                <tr {{ block.shopify_attributes }}>
                  <td>{{ block.settings.us_size }}</td>
                  <td>{{ block.settings.diameter }}</td>
                  <td>{{ block.settings.circumference }}</td>
                  <td>{{ block.settings.uk_size }}</td>
                  <td>{{ block.settings.europe_size }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {%- endif -%}
    </div>
  </div>
</x-modal>

<script>
  // Handle clicks on links pointing to #size-guide-popup
  document.addEventListener('click', function(event) {
    const link = event.target.closest('a[href="#size-guide-popup"]');
    if (link) {
      event.preventDefault();
      const modal = document.getElementById('size-guide-popup');
      if (modal && typeof modal.show === 'function') {
        modal.show();
      } else if (modal) {
        modal.setAttribute('open', '');
      }
    }
  });
</script>

{% schema %}
