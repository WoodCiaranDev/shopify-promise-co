{%- assign promise_entries = shop.metaobjects.promise_entry.values -%}
{%- assign promise_count = 0 -%}

{%- comment -%} Debug: Show what we're working with {%- endcomment -%}
<!-- Debug: Total promise entries: {{ promise_entries.size }} -->
{%- for promise in promise_entries -%}
  <!-- Debug: Promise {{ forloop.index }}: location="{{ promise.location }}", show_on_map="{{ promise.show_on_map }}" -->
  {%- if promise.location != blank and promise.show_on_map == true -%}
    {%- assign promise_count = promise_count | plus: 1 -%}
    <!-- Debug: This promise will show on map -->
  {%- endif -%}
{%- endfor -%}
<!-- Debug: Final promise_count: {{ promise_count }} -->


{%- if promise_count > 0 -%}
  {%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

  <div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% if section.settings.use_compact_spacing %} section-spacing--compact{% endif %} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
    <div class="promise-map-wrapper">
      <div id="promise-map" class="promise-map" style="height: {{ section.settings.map_height }}px;"></div>
    </div>
  </div>

  {%- comment -%} Hidden promise data for JavaScript - now from metaobjects {%- endcomment -%}
  <script type="application/json" id="promise-map-data">
    {
      "promises": [
        {%- assign map_promises = '' -%}
        {%- for promise in promise_entries -%}
          {%- if promise.location != blank and promise.show_on_map == true -%}
            {%- unless map_promises == blank -%},{%- endunless -%}
            {
              "id": "promise-{{ forloop.index }}",
              "title": {{ promise.name | json }},
              "content": {{ promise.promise_content | strip_html | json }},
              "locationName": {{ promise.location | json }},
              "latitude": {{ promise.latitude | json }},
              "longitude": {{ promise.longitude | json }},
              "image": null
            }
            {%- assign map_promises = map_promises | append: 'x' -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>

  {%- comment -%} Leaflet CSS and JavaScript {%- endcomment -%}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
          crossorigin=""></script>

  <script>
    // Initialize map when page loads
    document.addEventListener('DOMContentLoaded', function() {
      initPromiseMap();
    });

    function initPromiseMap() {
      const mapData = JSON.parse(document.getElementById('promise-map-data').textContent);
      const mapElement = document.getElementById('promise-map');

      if (!mapElement || !mapData.promises.length) return;

      // Initialize Leaflet map with OpenStreetMap tiles
      const map = L.map('promise-map', {
        center: [20, 0], // [lat, lng]
        zoom: 2,
        zoomControl: true,
        scrollWheelZoom: true
      });

      // Add OpenStreetMap tile layer
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        maxZoom: 19
      }).addTo(map);

      // Create custom icon using your existing marker image
      const customIcon = L.icon({
        iconUrl: '{{ "map-marker.png" | asset_url }}',
        iconSize: [28, 44],
        iconAnchor: [14, 44], // Point of the icon which will correspond to marker's location
        popupAnchor: [0, -44] // Point from which the popup should open relative to the iconAnchor
      });

      // Track bounds to fit all markers
      const bounds = L.latLngBounds();
      let markerCount = 0;

      // Function to create marker
      function createMarker(promise, lat, lng) {
        // Popup content
        const popupContent = `
          <div class="promise-popup">
            <div class="promise-popup__content">
              <h3 class="promise-popup__title">${promise.title}</h3>
              ${promise.locationName ? `<p class="promise-popup__location">${promise.locationName}</p>` : ''}
              <p class="promise-popup__text">${promise.content}</p>
            </div>
          </div>
        `;

        // Create marker with custom icon
        const marker = L.marker([lat, lng], { icon: customIcon })
          .bindPopup(popupContent)
          .addTo(map);

        // Extend bounds to include this marker
        bounds.extend([lat, lng]);
        markerCount++;
      }

      // Process each promise - now using stored coordinates!
      mapData.promises.forEach(promise => {
        // Check if we have stored coordinates
        if (promise.latitude && promise.longitude) {
          const lat = parseFloat(promise.latitude);
          const lng = parseFloat(promise.longitude);

          // Validate coordinates
          if (!isNaN(lat) && !isNaN(lng) && lat >= -90 && lat <= 90 && lng >= -180 && lng <= 180) {
            createMarker(promise, lat, lng);
          } else {
            console.warn(`Invalid coordinates for "${promise.locationName}": ${lat}, ${lng}`);
          }
        } else {
          console.warn(`No coordinates stored for "${promise.locationName}"`);
        }
      });

      // Fit map to show all markers
      if (markerCount > 0) {
        map.fitBounds(bounds, {
          padding: [50, 50],
          maxZoom: 8
        });
      }
    }

    // Fallback if Leaflet fails to load
    window.addEventListener('load', () => {
      setTimeout(() => {
        if (typeof L === 'undefined') {
          console.error('Leaflet failed to load');
          const mapElement = document.getElementById('promise-map');
          if (mapElement) {
            mapElement.innerHTML = '<div class="map-error" style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f5f5f5; color: #666;">Map could not be loaded. Please check your internet connection.</div>';
          }
        }
      }, 5000);
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Promise Map",
  "class": "shopify-section--promise-map",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "Separate section with border",
      "default": false
    },
    {
      "type": "range",
      "id": "map_height",
      "label": "Map height (pixels)",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500
    },
    {
      "type": "checkbox",
      "id": "remove_vertical_spacing",
      "label": "Remove vertical spacing",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "use_compact_spacing",
      "label": "Use compact vertical spacing",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "promise",
      "name": "Promise Location",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Promise image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Promise title",
          "default": "My Promise"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Promise content",
          "default": "This is my promise to the world..."
        },
        {
          "type": "text",
          "id": "location_name",
          "label": "Location name",
          "default": "City, Country",
          "info": "Display name for this location (e.g. 'London, UK')"
        },
        {
          "type": "text",
          "id": "latitude",
          "label": "Latitude",
          "info": "Find coordinates at latlong.net or google.com/maps"
        },
        {
          "type": "text",
          "id": "longitude",
          "label": "Longitude",
          "info": "Find coordinates at latlong.net or google.com/maps"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promise Map",
      "blocks": [
        {
          "type": "promise",
          "settings": {
            "title": "Love Always Wins",
            "content": "I promise to choose love over fear in every decision I make.",
            "location_name": "London, UK",
            "latitude": "51.5074",
            "longitude": "-0.1278"
          }
        },
        {
          "type": "promise",
          "settings": {
            "title": "Be Kind Always",
            "content": "I promise to show kindness to everyone I meet, no matter the circumstances.",
            "location_name": "New York, USA",
            "latitude": "40.7128",
            "longitude": "-74.0060"
          }
        }
      ]
    }
  ]
}
{% endschema %}
